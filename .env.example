# MongoDB Atlas (cole a connection string completa)
MONGODB_URI=mongodb+srv://USUARIO:SENHA@cluster.xxxxx.mongodb.net/barbell_cookies?retryWrites=true&w=majority

# Senha do painel /admin
ADMIN_PASSWORD=sua_senha_forte

PORT=3001

# --- Vercel / produção ---
# O site no Vercel NÃO roda o Express. Suba a API em Render/Railway (start: node server/index.mjs)
# e use UMA das opções:
#
# Opção A — no painel da Vercel → Environment Variables:
#   VITE_API_URL=https://sua-api.onrender.com   (HTTPS, sem barra no final)
# Depois: Redeploy. Não use localhost aqui.
#
# Opção B — copie vercel.json.example → vercel.json e troque a URL do rewrite para a mesma API.
#   Com proxy, pode deixar VITE_API_URL vazio no build.
#
# Atlas → Network Access: 0.0.0.0/0 (ou IP do host da API) para a API na nuvem conectar.
# VITE_API_URL=https://sua-api.com
